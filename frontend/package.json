{
  "name": "itms",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "frontend:dev": "node node_modules/vite/bin/vite.js --host 0.0.0.0 --port 5800",
    "backend:dev": "cd ../backend && go run ./cmd/server",
    "backend:build": "cd ../backend && go build ./cmd/server",
    "dev": "concurrently -k -n frontend,backend -c cyan,green \"npm:frontend:dev\" \"npm:backend:dev\"",
    "build": "node node_modules/typescript/bin/tsc -b && node node_modules/vite/bin/vite.js build",
    "lint": "eslint .",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "preview:stable": "bash ../scripts/start-itms-frontend.sh"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.8"
  }
}
